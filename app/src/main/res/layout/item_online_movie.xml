<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="220dp"
    android:layout_height="170dp"
    android:layout_marginHorizontal="8dp"
    card_view:cardBackgroundColor="@color/app_surface"
    card_view:cardCornerRadius="22dp"
    card_view:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="bottom"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvStreamLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/app_primary"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:text="STREAM"
            android:textColor="@color/app_primary_text"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvOnlineMovieTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="The Seventh Seal"
            android:textColor="@color/app_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvOnlineMovieDescription"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="A classic online stream."
            android:textColor="@color/app_text_secondary"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnPlayOnlineMovie"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:backgroundTint="@color/app_primary"
            android:text="Play"
            android:textColor="@color/app_primary_text"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.cardview.widget.CardView>