<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/detailsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="38dp"
        android:paddingEnd="22dp"
        android:paddingBottom="42dp">

        <TextView
            android:id="@+id/tvDetailsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Movie Title"
            android:textColor="@color/app_text_primary"
            android:textSize="31sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDetailsDirector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Director"
            android:textColor="@color/app_text_secondary"
            android:textSize="17sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvDetailsGenre"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_chip"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:text="Genre"
                android:textColor="@color/app_text_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvDetailsYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_chip"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:text="Year"
                android:textColor="@color/app_text_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvDetailsRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_badge_primary"
                android:gravity="center"
                android:minWidth="70dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:singleLine="true"
                android:text="★ 5.0"
                android:textColor="@color/app_primary_text"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvDetailsStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_chip_special"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:text="Status"
            android:textColor="@color/app_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDetailsFavorite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_chip"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:text="Library"
            android:textColor="@color/app_text_primary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Notes"
            android:textColor="@color/app_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDetailsNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_surface_panel"
            android:padding="18dp"
            android:text="Movie notes..."
            android:textColor="@color/app_text_secondary"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.2" />

        <TextView
            android:id="@+id/tvVideoInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="No video attached"
            android:textColor="@color/app_text_secondary"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnPlayMovie"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="22dp"
            android:backgroundTint="@color/app_primary"
            android:text="▶  Play Movie"
            android:textColor="@color/app_primary_text"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnEditMovie"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/app_button_dark"
            android:text="Edit Movie"
            android:textColor="@color/app_button_dark_text" />

        <Button
            android:id="@+id/btnShareMovie"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/app_button_dark"
            android:text="Share Movie"
            android:textColor="@color/app_button_dark_text" />

        <Button
            android:id="@+id/btnDeleteMovie"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/app_danger"
            android:text="Delete Movie"
            android:textColor="@color/app_danger_text" />

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/app_button_dark"
            android:text="Back"
            android:textColor="@color/app_button_dark_text" />

    </LinearLayout>

</ScrollView>
