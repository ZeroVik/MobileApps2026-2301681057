<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/addEditRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="38dp"
        android:paddingEnd="22dp"
        android:paddingBottom="42dp">

        <TextView
            android:id="@+id/tvScreenTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Movie"
            android:textColor="@color/app_text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Save movie details in your personal library."
            android:textColor="@color/app_text_secondary"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/etTitle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="26dp"
            android:backgroundTint="@color/app_primary"
            android:hint="Movie title"
            android:inputType="textCapWords"
            android:textColor="@color/app_text_primary"
            android:textColorHint="@color/app_text_secondary" />

        <EditText
            android:id="@+id/etDirector"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/app_primary"
            android:hint="Director"
            android:inputType="textCapWords"
            android:textColor="@color/app_text_primary"
            android:textColorHint="@color/app_text_secondary" />

        <EditText
            android:id="@+id/etGenre"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/app_primary"
            android:hint="Genre"
            android:inputType="textCapWords"
            android:textColor="@color/app_text_primary"
            android:textColorHint="@color/app_text_secondary" />

        <EditText
            android:id="@+id/etYear"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/app_primary"
            android:hint="Year"
            android:inputType="number"
            android:maxLength="4"
            android:textColor="@color/app_text_primary"
            android:textColorHint="@color/app_text_secondary" />

        <TextView
            android:id="@+id/tvStatusLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Movie status"
            android:textColor="@color/app_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerStatus"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/app_primary"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <EditText
            android:id="@+id/etRating"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/app_primary"
            android:hint="Rating 0 - 5"
            android:inputType="numberDecimal"
            android:textColor="@color/app_text_primary"
            android:textColorHint="@color/app_text_secondary" />

        <EditText
            android:id="@+id/etNotes"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/app_primary"
            android:gravity="top"
            android:hint="Notes"
            android:inputType="textMultiLine"
            android:paddingTop="12dp"
            android:textColor="@color/app_text_primary"
            android:textColorHint="@color/app_text_secondary" />

        <CheckBox
            android:id="@+id/cbFavorite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:buttonTint="@color/app_primary"
            android:text="Mark as favorite"
            android:textColor="@color/app_text_primary"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnUseOnlineStream"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="@color/app_primary"
            android:text="Use Online Stream"
            android:textColor="@color/app_primary_text"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnChooseVideo"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="@color/app_button_dark"
            android:text="Choose Local Video"
            android:textColor="@color/app_button_dark_text" />

        <TextView
            android:id="@+id/tvSelectedVideo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="No video selected"
            android:textColor="@color/app_text_secondary"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnSaveMovie"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="28dp"
            android:backgroundTint="@color/app_primary"
            android:text="Save Movie"
            android:textColor="@color/app_primary_text"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/app_button_dark"
            android:text="Cancel"
            android:textColor="@color/app_button_dark_text" />

    </LinearLayout>

</ScrollView>