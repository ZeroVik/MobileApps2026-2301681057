<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="230dp"
    android:layout_height="170dp"
    android:layout_marginHorizontal="8dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="6dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_hero_gradient">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_hero_overlay" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvStreamLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_primary"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="STREAM"
                android:textColor="@color/app_primary_text"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvOnlineMovieTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="The Seventh Seal"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvOnlineMovieDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:layout_marginBottom="12dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="A classic online stream."
                android:textColor="#C7FFFFFF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnPlayOnlineMovie"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:backgroundTint="@color/app_primary"
                android:text="▶  Play"
                android:textColor="@color/app_primary_text"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
